{
  "name": "@guiho/suraia-example-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "typecheck": "bunx --bun tsc -p . --noEmit",
    "build": "bunx --bun tsc -p . --noEmit && bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.ts"
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "6.0.3"
  }
}
