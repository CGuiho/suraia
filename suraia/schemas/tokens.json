{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Suraia Design Tokens Schema",
  "description": "JSON Schema for Suraia Design Tokens conforming to the W3C Community Group Design Tokens Format.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "color": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["$value", "$type"],
        "properties": {
          "$value": { "type": "string" },
          "$type": { "const": "color" }
        }
      }
    },
    "space": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["$value", "$type"],
        "properties": {
          "$value": { "type": "string" },
          "$type": { "const": "dimension" }
        }
      }
    },
    "radius": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["$value", "$type"],
        "properties": {
          "$value": { "type": "string" },
          "$type": { "const": "dimension" }
        }
      }
    },
    "border": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["$value", "$type"],
        "properties": {
          "$value": { "type": "string" },
          "$type": { "const": "dimension" }
        }
      }
    },
    "fontFamily": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["$value", "$type"],
        "properties": {
          "$value": { "type": "string" },
          "$type": { "const": "fontFamily" }
        }
      }
    },
    "fontSize": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["$value", "$type"],
        "properties": {
          "$value": { "type": "string" },
          "$type": { "const": "dimension" }
        }
      }
    },
    "shadow": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["$value", "$type"],
        "properties": {
          "$value": { "type": "string" },
          "$type": { "const": "shadow" }
        }
      }
    },
    "zIndex": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["$value", "$type"],
        "properties": {
          "$value": { "type": "string" },
          "$type": { "const": "number" }
        }
      }
    },
    "transition": {
      "type": "object",
      "properties": {
        "duration": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["$value", "$type"],
            "properties": {
              "$value": { "type": "string" },
              "$type": { "const": "duration" }
            }
          }
        },
        "easing": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["$value", "$type"],
            "properties": {
              "$value": { "type": "string" },
              "$type": { "const": "easing" }
            }
          }
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "color",
    "space",
    "radius",
    "border",
    "fontFamily",
    "fontSize",
    "shadow",
    "zIndex",
    "transition"
  ],
  "additionalProperties": false
}
