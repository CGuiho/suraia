{
  "$schema": "https://suraia.guiho.co/schemas/tokens.json",
  "color": {
    "brand": {
      "primary": { "$value": "#2563eb", "$type": "color" },
      "secondary": { "$value": "#475569", "$type": "color" }
    },
    "feedback": {
      "danger": { "$value": "#dc2626", "$type": "color" },
      "success": { "$value": "#16a34a", "$type": "color" },
      "warning": { "$value": "#ea580c", "$type": "color" },
      "info": { "$value": "#0284c7", "$type": "color" }
    },
    "neutral": {
      "white": { "$value": "#ffffff", "$type": "color" },
      "black": { "$value": "#000000", "$type": "color" },
      "transparent": { "$value": "transparent", "$type": "color" },
      "gray": {
        "50": { "$value": "#f8fafc", "$type": "color" },
        "100": { "$value": "#f1f5f9", "$type": "color" },
        "200": { "$value": "#e2e8f0", "$type": "color" },
        "300": { "$value": "#cbd5e1", "$type": "color" },
        "400": { "$value": "#94a3b8", "$type": "color" },
        "500": { "$value": "#64748b", "$type": "color" },
        "600": { "$value": "#475569", "$type": "color" },
        "700": { "$value": "#334155", "$type": "color" },
        "800": { "$value": "#1e293b", "$type": "color" },
        "900": { "$value": "#0f172a", "$type": "color" }
      }
    }
  },
  "space": {
    "0": { "$value": "0px", "$type": "dimension" },
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "20px", "$type": "dimension" },
    "6": { "$value": "24px", "$type": "dimension" },
    "8": { "$value": "32px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" }
  },
  "radius": {
    "none": { "$value": "0px", "$type": "dimension" },
    "xs": { "$value": "2px", "$type": "dimension" },
    "sm": { "$value": "4px", "$type": "dimension" },
    "md": { "$value": "6px", "$type": "dimension" },
    "lg": { "$value": "8px", "$type": "dimension" },
    "xl": { "$value": "12px", "$type": "dimension" },
    "2xl": { "$value": "16px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "fontFamily": {
    "sans": { "$value": "system-ui, -apple-system, sans-serif", "$type": "fontFamily" },
    "mono": { "$value": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace", "$type": "fontFamily" }
  },
  "fontSize": {
    "xs": { "$value": "12px", "$type": "dimension" },
    "sm": { "$value": "14px", "$type": "dimension" },
    "md": { "$value": "16px", "$type": "dimension" },
    "lg": { "$value": "18px", "$type": "dimension" },
    "xl": { "$value": "20px", "$type": "dimension" },
    "2xl": { "$value": "24px", "$type": "dimension" }
  },
  "shadow": {
    "none": { "$value": "none", "$type": "shadow" },
    "sm": { "$value": "0 1px 2px 0 rgba(0, 0, 0, 0.05)", "$type": "shadow" },
    "md": { "$value": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)", "$type": "shadow" },
    "lg": { "$value": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)", "$type": "shadow" }
  }
}
